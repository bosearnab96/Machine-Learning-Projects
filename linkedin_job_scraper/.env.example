# ── Copy this file to .env and fill in your real values ──────────────────────
# NEVER commit .env to git.

# ── LinkedIn account ──────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Gmail sender (the account that sends the digest) ─────────────────────────
GMAIL_SENDER=your_gmail@gmail.com

# Gmail App Password — NOT your regular Gmail password.
# Create at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be on)
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email recipient (defaults to GMAIL_SENDER if left blank) ─────────────────
ALERT_RECIPIENT=your_gmail@gmail.com

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative or absolute).
DB_PATH=seen_posts.db

# ── Scheduler — time of day to send digest (UTC, 24-hour) ────────────────────
# 18:00 UTC = roughly 6 PM; adjust to your local EOD.
DIGEST_HOUR=18
DIGEST_MINUTE=0
