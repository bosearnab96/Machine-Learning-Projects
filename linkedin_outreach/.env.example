# Optional — only if you want headless Slack/email alerts on failure
ALERT_EMAIL=
ALERT_SMTP_PASSWORD=

# Timezone for "working hours" gating
LOCAL_TZ=Asia/Kolkata

# Override if you want to test faster — defaults are conservative
MAX_REQUESTS_PER_HOUR=4
MIN_REQUESTS_PER_HOUR=2

# Working-hours window (24h local time)
WORK_START_HOUR=10
WORK_END_HOUR=19

# 0=Monday … 6=Sunday. Default skips weekends.
WORK_DAYS=0,1,2,3,4

# Where Chrome persistent profile lives
CHROME_PROFILE_DIR=./chrome_profile
